{
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6"
  },
  "attribution": {
    "commit": ""
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/ai-agents/.claude/statusline.sh",
    "padding": 0,
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "theme": "light-ansi",
  "editorMode": "vim",
  "includeCoAuthoredBy": false,
  "language": "russian",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "voiceEnabled": true
}
